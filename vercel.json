{
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/main.py" },
    { "src": "/health", "dest": "/api/main.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/main.py" }
  ]
}
