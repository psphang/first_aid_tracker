{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://first-aid-tracker.onrender.com/api/$1"
    },
    {
      "source": "/kit/(.*)",
      "destination": "/static/index.html"
    },
    {
      "source": "/edit_items",
      "destination": "/static/edit_items.html"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    }
  ]
}
